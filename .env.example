# LinkedIn API credentials (v2 API + OAuth 2.0)
# Get these from https://www.linkedin.com/developers
MSEND_LINKEDIN_ACCESS_TOKEN=
MSEND_LINKEDIN_PERSON_URN=

# Bluesky API credentials (AT Protocol + App Password)
# Get an App Password from Settings → App Passwords at https://bsky.app/settings
MSEND_BLUESKY_HANDLE=
MSEND_BLUESKY_APP_PASSWORD=

# Mastodon API credentials (OAuth access token)
# Generate at: Preferences → Development → New Application on your instance
# Scopes: write:statuses, write:media
MSEND_MASTODON_INSTANCE=https://mastodon.social
MSEND_MASTODON_ACCESS_TOKEN=
